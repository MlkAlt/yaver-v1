# Yaver V1 — Environment Variables
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur
# .env.local asla git'e commit edilmez (K7 kuralı)
#
# Değerleri nereden alırsın:
#   Supabase Dashboard > Settings > API

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# SERVICE_ROLE_KEY — sadece MCP ve backend için, frontend'e asla verme
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Anthropic API (Hafta 2'de eklenecek)
# ANTHROPIC_API_KEY=sk-ant-...
